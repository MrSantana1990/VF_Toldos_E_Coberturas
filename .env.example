# ===== Frontend (Vite) =====
# URL opcional do logo (ex.: link direto de imagem do Drive / CDN)
VITE_LOGO_URL=

# URL do portal OAuth (ex.: https://... )
VITE_OAUTH_PORTAL_URL=

# ID do app/projeto (usado no OAuth e no backend)
VITE_APP_ID=

# Analytics (opcional - Umami)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# Map / Forge (se aplicável)
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=

# ===== Backend =====
# Segredo para assinar/verificar JWT de sessão
JWT_SECRET=

# Conexão MySQL (Drizzle)
DATABASE_URL=

# ===== Google Drive (armazenamento de orçamentos/galeria) =====
# Observação:
# - Para *exibir* imagens/logo (pasta pública com link), basta definir a pasta de imagens abaixo.
# - Para *salvar* orçamentos no Drive, é necessária uma Service Account com permissão de Editor na pasta.
#
# Use uma Service Account e compartilhe a(s) pasta(s) do Drive com o e-mail dela (permissão de Editor).
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Cole a chave privada; em providers como Netlify, use \\n no lugar de quebras de linha.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Pasta onde serão salvos os orçamentos (arquivos JSON)
GOOGLE_DRIVE_QUOTES_FOLDER_ID=

# Pasta onde ficam as imagens da galeria/portfolio
# (opcional) Se não definir, o projeto usa por padrão: 1eb1HNBEMNyWPrTBrtgSUsw3HXA36VnOR
GOOGLE_DRIVE_IMAGES_FOLDER_ID=1eb1HNBEMNyWPrTBrtgSUsw3HXA36VnOR

# OAuth server (backend)
OAUTH_SERVER_URL=

# OpenId do dono/admin do sistema
OWNER_OPEN_ID=

# Serviços Forge/Manus (notificações/storage - se aplicável)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
